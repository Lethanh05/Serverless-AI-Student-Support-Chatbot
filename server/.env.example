PORT=8080

# Cloud SQL connection options:
# Use DB_HOST/DB_PORT for local development
# Use INSTANCE_CONNECTION_NAME (or DB_SOCKET_PATH) when running on Cloud Run
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=uth_app
DB_PASSWORD=change-me
DB_NAME=uth_chatbot

# Optional for Cloud Run + Cloud SQL
# INSTANCE_CONNECTION_NAME=my-project:us-central1:uth-chatbot-mysql
# DB_SOCKET_PATH=/cloudsql/my-project:us-central1:uth-chatbot-mysql

JWT_SECRET=replace-with-strong-secret
GEMINI_API_KEY=replace-with-gemini-key
PORTAL_ENCRYPTION_KEY=replace-with-32-char-key

PYTHON_SERVICE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5173

# In Cloud production, set DB_BOOTSTRAP=false after schema has been initialized once.
DB_BOOTSTRAP=true
DB_CONNECTION_LIMIT=10
